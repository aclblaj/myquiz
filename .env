# Docker environment configuration for MyQuiz application

# Database Configuration
POSTGRES_DB=myquiz
POSTGRES_USER=myquiz_user
POSTGRES_PASSWORD=myquiz_password

# Application Configuration
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/myquiz
SPRING_DATASOURCE_USERNAME=myquiz_user
SPRING_DATASOURCE_PASSWORD=myquiz_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Logging Configuration
LOGGING_LEVEL_COM_UNITBV_MYQUIZ=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN
LOGGING_LEVEL_ROOT=WARN

# File Upload Configuration
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# Ollama AI Configuration (optional)
OLLAMA_BASE_URL=http://ollama:11434
